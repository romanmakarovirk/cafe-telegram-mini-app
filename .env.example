# ══════════════════════════════════════════════════════════════════════════════
#  Конфигурация кафе «Шашлык и Плов» — Telegram Mini App
# ══════════════════════════════════════════════════════════════════════════════
#
#  ВНИМАНИЕ: Этот файл — ШАБЛОН. Скопируйте его как .env и заполните значения.
#  НИКОГДА не коммитьте .env в git! Только .env.example.
#
#  На Render.com: все секреты вводятся через Dashboard → Environment Variables
# ══════════════════════════════════════════════════════════════════════════════

# ── ОБЯЗАТЕЛЬНО в продакшене ──────────────────────────────────────────────

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=

# ID чата администратора (получить через /admin команду бота)
ADMIN_CHAT_ID=

# Список Telegram ID администраторов через запятую
ALLOWED_ADMIN_IDS=

# API-ключ для кухонного принтера и admin-эндпоинтов (придумайте надёжный)
KITCHEN_API_KEY=

# ── Общие настройки ───────────────────────────────────────────────────────

# Публичный URL приложения (Render выдаёт автоматически)
WEBAPP_URL=https://your-app.onrender.com
APP_BASE_URL=https://your-app.onrender.com

# База данных (Render подставляет автоматически для PostgreSQL)
DATABASE_URL=sqlite:///./app.db

# Режим разработки (НИКОГДА не true в продакшене!)
DEV_MODE=false

# Таймаут оплаты в минутах (авто-отмена неоплаченных заказов)
ORDER_PAYMENT_TIMEOUT_MINUTES=15

# Дополнительные CORS origins через запятую
EXTRA_CORS_ORIGINS=

# ── ЮKassa (оплата + автоматическая фискализация 54-ФЗ) ──────────────────
# Регистрация: https://yookassa.ru/connection/
# YOOKASSA_TEST_MODE=true → тестовый режим (реальные деньги НЕ списываются)
# YOOKASSA_TEST_MODE=false → боевой режим (РЕАЛЬНЫЕ платежи!)

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_TEST_MODE=true
YOOKASSA_RETURN_URL=https://t.me/your_bot

# Реквизиты компании (для чеков 54-ФЗ)
COMPANY_INN=
COMPANY_EMAIL=
COMPANY_SNO=usn_income

# ── [DEPRECATED] СБП Сбербанк — сохранено для возможного отката ──────────
# SBP_USERNAME=
# SBP_PASSWORD=
# SBP_TOKEN=
# SBP_CALLBACK_SECRET=
# SBP_TEST_MODE=true

# ── [DEPRECATED] АТОЛ Онлайн — заменён автофискализацией ЮKassa ──────────
# ATOL_LOGIN=
# ATOL_PASSWORD=
# ATOL_GROUP_CODE=
# ATOL_INN=
# ATOL_COMPANY_EMAIL=
# ATOL_PAYMENT_ADDRESS=
# ATOL_SNO=usn_income
# ATOL_TEST_MODE=true

# ── 1С:Fresh OData (бухгалтерия) ─────────────────────────────────────────
# Создайте информационную базу на аккаунте клиента
# FRESH_ENABLED=false → интеграция отключена (можно включить позже)

FRESH_BASE_URL=
FRESH_USERNAME=
FRESH_PASSWORD=
FRESH_ENABLED=false
